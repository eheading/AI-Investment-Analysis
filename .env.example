# OpenRouter API Key (required) - get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model for analysis
OPENROUTER_MODEL=openai/gpt-4o

# Server ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/investment.db

# Summary generation interval (minutes)
SUMMARY_INTERVAL_MINUTES=60
